{
  "name": "boardroom",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 7391",
    "build": "next build && node scripts/fix-symlinks.js",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "concurrently \"next dev -p 7391\" \"wait-on http://localhost:7391 && NODE_ENV=development electron .\"",
    "electron:build": "next build && electron-builder --mac && node scripts/fix-native-modules.js",
    "electron:pack": "electron-builder --mac --dir && node scripts/fix-native-modules.js"
  },
  "build": {
    "appId": "com.abhipoluri.boardroom",
    "productName": "Boardroom",
    "directories": {
      "output": "dist"
    },
    "asar": false,
    "files": [
      "**/*",
      "!dist/**",
      "!*.md",
      "!.git/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "electron/icon.png"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@base-ui/react": "^1.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "framer-motion": "^12.37.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "node-pty": "^1.2.0-beta.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.4"
  }
}
