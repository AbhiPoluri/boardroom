# Boardroom Production Environment
# Copy to .env.local on your production server and fill in values

# Database path (SQLite) — use a persistent volume in Docker
DB_PATH=/data/boardroom.db

# Server port
PORT=3000

# Public URL — set to your actual domain
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API key for protecting all API endpoints
# Generate with: openssl rand -hex 32
# Leave empty to disable auth (dev mode only)
BOARDROOM_API_KEY=

# Anthropic API key (optional — only needed for orchestrator CLI calls)
ANTHROPIC_API_KEY=
